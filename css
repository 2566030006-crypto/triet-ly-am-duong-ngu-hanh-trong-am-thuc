body {
  font-family: Arial, sans-serif;
  line-height: 1.7;
  color: #222;
}

.article {
  max-width: 700px;
  margin: auto;
}

.title {
  font-size: 32px;
  font-weight: bold;
}

.content p {
  margin: 16px 0;
  font-size: 18px;
}

figure img {
  width: 100%;
  border-radius: 6px;
}

figcaption {
  font-size: 14px;
  color: #666;
  text-align: center;
}